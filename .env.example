# LINE Bot 設定（從 LINE Developers Console 取得）
LINE_CHANNEL_ACCESS_TOKEN=your_channel_access_token_here
LINE_CHANNEL_SECRET=your_channel_secret_here

# 你的 LINE User ID（房東 ID，用於接收通知）
OWNER_LINE_USER_ID=your_line_user_id_here

# Supabase PostgreSQL 連線字串
DATABASE_URL=postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres
DIRECT_URL=postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres

# 管理後台總管理員金鑰
ADMIN_KEY=your_admin_key_here
INTERNAL_SECRET=your_internal_api_secret_here
ADMIN_NOTIFY_LINE_USER_ID=your_admin_notify_line_user_id_here

# Server Port
PORT=3000

# 小蝸網站同步（更新房源後自動 revalidate）
SITE_URL=https://your-xiaowo-site.vercel.app
REVALIDATE_SECRET=your_random_secret_here

# Cloudinary 圖片儲存
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
